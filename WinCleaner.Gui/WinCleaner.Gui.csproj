<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>WinExe</OutputType>
        <TargetFramework>net8.0-windows</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <UseWPF>true</UseWPF>
        <RootNamespace>WinCleaner.Gui</RootNamespace>
        <AssemblyName>WinCleanerGui</AssemblyName>

        <Product>WinCleaner GUI</Product>
        <Authors>Clemens Jele</Authors>
        <Version>2.0.0</Version>
        <AssemblyVersion>2.0.0.0</AssemblyVersion>
        <FileVersion>2.0.0.0</FileVersion>
        <InformationalVersion>2.0.0</InformationalVersion>

        <ApplicationManifest>app.manifest</ApplicationManifest>
        <ApplicationIcon>Assets\wincleaner.ico</ApplicationIcon>
        <RuntimeIdentifier Condition="'$(RuntimeIdentifier)' == '' and '$(PublishSingleFile)' == 'true'">win-x64</RuntimeIdentifier>
    </PropertyGroup>

    <ItemGroup>
        <!-- Direkte Wiederverwendung der Core-/SystemTools-Logik (wie WinCleaner.Tests). -->
        <ProjectReference Include="..\WinCleaner\WinCleaner.csproj" />
    </ItemGroup>

</Project>
