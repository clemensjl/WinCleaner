<UserControl x:Class="WinCleaner.Gui.Views.StorageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28,24,28,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="3*" />
            <RowDefinition Height="2*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Speicher" Style="{StaticResource H1}" />

        <!-- Pfadleiste -->
        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Text="{Binding Path, UpdateSourceTrigger=PropertyChanged}"
                     VerticalContentAlignment="Center" />
            <Button Grid.Column="1" Content="Analysieren" Style="{StaticResource PrimaryButton}"
                    Command="{Binding AnalyzeCommand}" Margin="8,0,0,0" />
            <Button Grid.Column="2" Content="Duplikate finden" Style="{StaticResource SecondaryButton}"
                    Command="{Binding DuplicatesCommand}" Margin="8,0,0,0" />
        </Grid>

        <!-- Scan-Optionen -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <CheckBox Grid.Column="0" Content="Schneller NTFS-Scan (Admin)"
                      IsChecked="{Binding FastScan}" VerticalAlignment="Center"
                      ToolTip="Liest das NTFS-Inventar direkt (deutlich schneller). Ohne Adminrechte fragt Windows per UAC nach; wird das abgelehnt, läuft der Standard-Scan – die Statuszeile zeigt es an." />
            <Button Grid.Column="1" Content="HTML-Report erstellen" Style="{StaticResource SecondaryButton}"
                    Command="{Binding HtmlReportCommand}"
                    ToolTip="Erstellt einen interaktiven Treemap-Report als HTML-Datei und öffnet ihn im Browser." />
        </Grid>

        <!-- Zwei Bereiche: Analyse + Duplikate -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Größte Ordner/Dateien -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,6,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Größte Ordner &amp; Dateien" Style="{StaticResource H2}" />
                    <TextBlock DockPanel.Dock="Top" Text="{Binding DiskSummary}" Style="{StaticResource Muted}" Margin="0,4,0,10" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding DiskItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="58" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Path}" Style="{StaticResource Body}"
                                                   TextTrimming="CharacterEllipsis" Margin="0,0,8,0" />
                                        <TextBlock Grid.Column="1" Text="{Binding SizeText}" FontFamily="{StaticResource FontMono}"
                                                   Foreground="{DynamicResource TextPrimary}" HorizontalAlignment="Right" />
                                        <TextBlock Grid.Column="2" Text="{Binding PercentText}" Style="{StaticResource Muted}"
                                                   HorizontalAlignment="Right" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Duplikate -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="6,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Duplikate" Style="{StaticResource H2}" />
                    <TextBlock DockPanel.Dock="Top" Text="{Binding DupSummary}" Style="{StaticResource Muted}" Margin="0,4,0,10" />

                    <!-- Aktion: Hardlink-Ersetzung (Preview-first) -->
                    <Grid DockPanel.Dock="Bottom" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Behalten:" Style="{StaticResource Muted}"
                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                        <ComboBox Grid.Column="1" ItemsSource="{Binding KeepStrategies}" DisplayMemberPath="Label"
                                  SelectedItem="{Binding DupKeep}" HorizontalAlignment="Left" MinWidth="128"
                                  VerticalAlignment="Center" />
                        <Button Grid.Column="2" Content="Durch Hardlinks ersetzen" Style="{StaticResource SecondaryButton}"
                                Command="{Binding HardLinkCommand}" Margin="8,0,0,0"
                                ToolTip="Ersetzt Kopien durch NTFS-Hardlinks auf die behaltene Datei (spart Platz, Inhalt bleibt überall verfügbar). Erst Probelauf mit Bestätigung." />
                    </Grid>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Duplicates}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,6">
                                        <TextBlock Text="{Binding Header}" FontFamily="{StaticResource FontMono}"
                                                   Foreground="{DynamicResource Accent}" />
                                        <TextBlock Text="{Binding Files}" Style="{StaticResource Muted}" Margin="0,2,0,0" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Bild-Duplikate -->
        <Border Grid.Row="4" Style="{StaticResource Card}" Margin="0,12,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Bild-Duplikate" Style="{StaticResource H2}" />
                <TextBlock DockPanel.Dock="Top" Style="{StaticResource Muted}" Margin="0,4,0,0"
                           Text="Findet visuell ähnliche Bilder (skalierte oder neu komprimierte Kopien), auch wenn die Dateien nicht byte-identisch sind." />

                <!-- Eingaben -->
                <Grid DockPanel.Dock="Top" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding ImagePath, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="Schwelle:" Style="{StaticResource Muted}"
                               VerticalAlignment="Center" Margin="10,0,6,0"
                               ToolTip="0 = nur exakt gleicher Bild-Hash, 16 = sehr tolerant. Standard: 5." />
                    <Slider Grid.Column="2" Style="{StaticResource InstrumentSlider}" Width="120"
                            Minimum="0" Maximum="16" TickFrequency="1" IsSnapToTickEnabled="True"
                            Value="{Binding ImageThreshold}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="3" Text="{Binding ImageThreshold}" FontFamily="{StaticResource FontMono}"
                               Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"
                               Margin="8,0,0,0" MinWidth="18" TextAlignment="Right" />
                    <CheckBox Grid.Column="4" Content="Unterordner" IsChecked="{Binding ImageRecurse}"
                              VerticalAlignment="Center" Margin="14,0,0,0" />
                    <Button Grid.Column="5" Content="Bilder scannen" Style="{StaticResource PrimaryButton}"
                            Command="{Binding FindImagesCommand}" Margin="12,0,0,0" />
                </Grid>

                <TextBlock DockPanel.Dock="Top" Text="{Binding ImageSummary}" Style="{StaticResource Muted}" Margin="0,8,0,8" />

                <!-- Aktion: in den Papierkorb (Preview-first) -->
                <Grid DockPanel.Dock="Bottom" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Behalten:" Style="{StaticResource Muted}"
                               VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox Grid.Column="1" ItemsSource="{Binding KeepStrategies}" DisplayMemberPath="Label"
                              SelectedItem="{Binding ImageKeep}" HorizontalAlignment="Left" MinWidth="128"
                              VerticalAlignment="Center" />
                    <Button Grid.Column="2" Content="In den Papierkorb verschieben" Style="{StaticResource SecondaryButton}"
                            Command="{Binding DeleteImagesCommand}" Margin="8,0,0,0"
                            ToolTip="Verschiebt je Gruppe alle Bilder außer dem behaltenen in den Papierkorb (umkehrbar). Erst Probelauf mit Bestätigung." />
                </Grid>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ImageGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,6">
                                    <TextBlock Text="{Binding Header}" FontFamily="{StaticResource FontMono}"
                                               Foreground="{DynamicResource Accent}" />
                                    <TextBlock Text="{Binding Files}" Style="{StaticResource Muted}" Margin="0,2,0,0" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
