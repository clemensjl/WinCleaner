<UserControl x:Class="WinCleaner.Gui.Views.CleanupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28,24,28,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Kopf -->
        <Grid Grid.Row="0">
            <StackPanel>
                <TextBlock Text="Aufräumen" Style="{StaticResource H1}" />
                <TextBlock Text="{Binding Summary}" Style="{StaticResource Muted}" Margin="0,4,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <Button Content="Erneut scannen" Style="{StaticResource SecondaryButton}"
                        Command="{Binding ScanCommand}" Margin="0,0,8,0" />
                <Button Content="Ausgewählte bereinigen" Style="{StaticResource PrimaryButton}"
                        Command="{Binding CleanCommand}" />
            </StackPanel>
        </Grid>

        <!-- Spaltenkopf -->
        <Grid Grid.Row="1" Margin="14,20,26,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30" />
                <ColumnDefinition Width="2.2*" />
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="90" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="1" Text="KATEGORIE" Style="{StaticResource Eyebrow}" />
            <TextBlock Grid.Column="2" Text="PFAD" Style="{StaticResource Eyebrow}" />
            <TextBlock Grid.Column="3" Text="GRÖSSE" Style="{StaticResource Eyebrow}" HorizontalAlignment="Right" />
            <TextBlock Grid.Column="4" Text="STATUS" Style="{StaticResource Eyebrow}" HorizontalAlignment="Right" />
        </Grid>

        <!-- Liste -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="6">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30" />
                                    <ColumnDefinition Width="2.2*" />
                                    <ColumnDefinition Width="3*" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="90" />
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                          IsEnabled="{Binding IsSafe}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding Category}" Style="{StaticResource Body}"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,10,0" />
                                <TextBlock Grid.Column="2" Text="{Binding Path}" Style="{StaticResource Muted}"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,10,0" />
                                <TextBlock Grid.Column="3" Text="{Binding SizeText}" FontFamily="{StaticResource FontMono}"
                                           Foreground="{DynamicResource TextPrimary}"
                                           VerticalAlignment="Center" HorizontalAlignment="Right" />
                                <TextBlock Grid.Column="4" Text="{Binding SafetyText}" Style="{StaticResource Muted}"
                                           VerticalAlignment="Center" HorizontalAlignment="Right" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
