<UserControl x:Class="WinCleaner.Gui.Views.PrivacyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28,24,28,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <StackPanel>
                <TextBlock Text="Privatsphäre" Style="{StaticResource H1}" />
                <TextBlock Text="{Binding Summary}" Style="{StaticResource Muted}" Margin="0,4,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <CheckBox Content="Erweitert" IsChecked="{Binding Advanced}" VerticalAlignment="Center" Margin="0,0,14,0" />
                <Button Content="Anwenden" Style="{StaticResource PrimaryButton}"
                        Command="{Binding ApplyCommand}" Margin="0,0,8,0" />
                <Button Content="Rückgängig" Style="{StaticResource SecondaryButton}"
                        Command="{Binding UndoCommand}" />
            </StackPanel>
        </Grid>

        <Button Grid.Row="1" Content="Telemetrie-Hosts blocken (hosts-Datei)" Style="{StaticResource SecondaryButton}"
                HorizontalAlignment="Left" Command="{Binding BlockTelemetryCommand}" Margin="0,14,0,0" />

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="6" Margin="0,14,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="100" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Description}" Style="{StaticResource Body}"
                                           TextTrimming="CharacterEllipsis" Margin="0,0,8,0" />
                                <TextBlock Grid.Column="1" Text="{Binding Profile}" Style="{StaticResource Muted}" />
                                <TextBlock Grid.Column="2" Text="{Binding Hive}" Style="{StaticResource Muted}" />
                                <TextBlock Grid.Column="3" Text="{Binding StatusText}" HorizontalAlignment="Right"
                                           Foreground="{DynamicResource TextPrimary}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
