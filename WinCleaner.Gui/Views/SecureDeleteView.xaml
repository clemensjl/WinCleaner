<UserControl x:Class="WinCleaner.Gui.Views.SecureDeleteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28,24,28,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Sicher löschen" Style="{StaticResource H1}" />

        <!-- Warnbanner -->
        <Border Grid.Row="1" Background="{DynamicResource DangerSoft}" BorderBrush="{DynamicResource Danger}"
                BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE7BA;" FontFamily="{StaticResource FontIcon}" FontSize="16"
                           Foreground="{DynamicResource Danger}" VerticalAlignment="Center" Margin="0,0,10,0" />
                <TextBlock Style="{StaticResource Body}" VerticalAlignment="Center"
                           Text="Diese Aktionen sind UNWIDERRUFLICH – kein Papierkorb, keine Wiederherstellung. Auf SSDs ist Überschreiben wirkungslos." />
            </StackPanel>
        </Border>

        <!-- Shred -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,14,0,0">
            <StackPanel>
                <TextBlock Text="Datei/Ordner endgültig löschen" Style="{StaticResource H2}" />
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding ShredPath, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBlock Text="Durchgänge:" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBox Text="{Binding Passes}" Width="42" VerticalContentAlignment="Center"
                                 TextAlignment="Center" />
                    </StackPanel>
                    <Button Grid.Column="2" Content="Endgültig löschen" Style="{StaticResource DangerButton}"
                            Command="{Binding ShredCommand}" Margin="10,0,0,0" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Wipe free space -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock Text="Freien Speicher überschreiben" Style="{StaticResource H2}" />
                <TextBlock Style="{StaticResource Muted}" Margin="0,6,0,0"
                           Text="Tilgt Reste bereits gelöschter Dateien. Belegte Dateien bleiben unangetastet." />
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Laufwerk:" Style="{StaticResource Muted}"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox Grid.Column="1" Text="{Binding WipeDrive, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center" HorizontalAlignment="Left" Width="90" />
                    <Button Grid.Column="2" Content="Freien Speicher überschreiben" Style="{StaticResource DangerButton}"
                            Command="{Binding WipeCommand}" />
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
