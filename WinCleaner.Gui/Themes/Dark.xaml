<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dunkles Instrumenten-Design (Standard). Farben tragen Bedeutung:
         Grün = sicher, Amber = Vorsicht, Rot = unwiderruflich. -->
    <Color x:Key="BgBaseColor">#14181D</Color>
    <Color x:Key="BgSurfaceColor">#1C2229</Color>
    <Color x:Key="BgSurfaceAltColor">#232B34</Color>
    <Color x:Key="BorderColor">#2A323C</Color>
    <Color x:Key="TextPrimaryColor">#E6EBF0</Color>
    <Color x:Key="TextMutedColor">#8A97A6</Color>
    <Color x:Key="AccentColor">#35C6A5</Color>
    <Color x:Key="AccentDimColor">#2A9E85</Color>
    <Color x:Key="AccentSoftColor">#1E2E2C</Color>
    <Color x:Key="CautionColor">#E0A93B</Color>
    <Color x:Key="DangerColor">#E5484D</Color>
    <Color x:Key="DangerSoftColor">#2E1E20</Color>
    <Color x:Key="OnAccentColor">#0C1210</Color>

    <SolidColorBrush x:Key="BgBase" Color="{StaticResource BgBaseColor}" />
    <SolidColorBrush x:Key="BgSurface" Color="{StaticResource BgSurfaceColor}" />
    <SolidColorBrush x:Key="BgSurfaceAlt" Color="{StaticResource BgSurfaceAltColor}" />
    <SolidColorBrush x:Key="Border" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="TextPrimary" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextMuted" Color="{StaticResource TextMutedColor}" />
    <SolidColorBrush x:Key="Accent" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentDim" Color="{StaticResource AccentDimColor}" />
    <SolidColorBrush x:Key="AccentSoft" Color="{StaticResource AccentSoftColor}" />
    <SolidColorBrush x:Key="Caution" Color="{StaticResource CautionColor}" />
    <SolidColorBrush x:Key="Danger" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="DangerSoft" Color="{StaticResource DangerSoftColor}" />
    <SolidColorBrush x:Key="OnAccent" Color="{StaticResource OnAccentColor}" />

</ResourceDictionary>
