<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Sichtbarkeit an bool koppeln (z. B. Fortschrittsbalken bei Busy). -->
    <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

    <!-- ===== Typografie ===== -->
    <FontFamily x:Key="FontUi">Segoe UI Variable Text, Segoe UI</FontFamily>
    <FontFamily x:Key="FontDisplay">Segoe UI Variable Display, Segoe UI Semibold, Segoe UI</FontFamily>
    <!-- Ziffern/Messwerte im Monospace-Readout-Stil (Signatur). -->
    <FontFamily x:Key="FontMono">Cascadia Mono, Consolas, Courier New</FontFamily>
    <!-- Native Icon-Schrift für die Navigationsglyphen. -->
    <FontFamily x:Key="FontIcon">Segoe Fluent Icons, Segoe MDL2 Assets</FontFamily>

    <!-- Fließtext -->
    <Style x:Key="Body" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontUi}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="Muted" TargetType="TextBlock" BasedOn="{StaticResource Body}">
        <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
    </Style>

    <!-- Seitentitel -->
    <Style x:Key="H1" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontDisplay}" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>

    <Style x:Key="H2" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontDisplay}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>

    <!-- Kleiner Großbuchstaben-Label über Werten (Instrumenten-Stil) -->
    <Style x:Key="Eyebrow" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontUi}" />
        <Setter Property="FontSize" Value="10.5" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
        <Setter Property="Typography.Capitals" Value="AllSmallCaps" />
    </Style>

    <!-- Große Kennzahl im Monospace-Readout -->
    <Style x:Key="Metric" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontMono}" />
        <Setter Property="FontSize" Value="30" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>

    <!-- ===== Karte (Hairline-Rahmen statt Schatten) ===== -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BgSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="18" />
    </Style>

    <!-- ===== Buttons ===== -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource FontUi}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource OnAccent}" />
        <Setter Property="Background" Value="{DynamicResource Accent}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="16,9" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource AccentDim}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="b" Property="Opacity" Value="0.4" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Sekundär: neutraler Umriss -->
    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="Background" Value="{DynamicResource BgSurfaceAlt}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource Border}" BorderThickness="1"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Accent}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="b" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Gefahr: für unwiderrufliche Aktionen (shred/wipe) -->
    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="{DynamicResource Danger}" />
    </Style>

    <!-- ===== Navigations-Element (ListBoxItem als Rail-Eintrag) =====
         DataContext eines Eintrags ist ein PageViewModel mit Title + Glyph. -->
    <Style x:Key="NavItem" TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Margin" Value="8,1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="b" Background="Transparent" CornerRadius="6" Padding="6,9">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="bar" Grid.Column="0" Width="3" Height="16"
                                    CornerRadius="2" Background="Transparent"
                                    HorizontalAlignment="Left" Margin="0,0,9,0" />
                            <TextBlock x:Name="glyph" Grid.Column="1" Margin="0,0,10,0"
                                       FontFamily="{StaticResource FontIcon}" FontSize="15"
                                       VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}"
                                       Text="{Binding Glyph}" />
                            <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                       FontFamily="{StaticResource FontUi}" FontSize="13"
                                       Foreground="{TemplateBinding Foreground}"
                                       Text="{Binding Title}" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource BgSurfaceAlt}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource AccentSoft}" />
                            <Setter TargetName="bar" Property="Background" Value="{DynamicResource Accent}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Selektierbare Listenzeile (Programme/Autostart) -->
    <Style x:Key="Row" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="b" Background="Transparent" CornerRadius="5"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource BgSurfaceAlt}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource AccentSoft}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Standard-Steuerelemente an Theme angleichen ===== -->
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontUi}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="FontFamily" Value="{StaticResource FontUi}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource FontUi}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="Background" Value="{DynamicResource BgBase}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="CaretBrush" Value="{DynamicResource TextPrimary}" />
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="FontFamily" Value="{StaticResource FontUi}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="8,5" />
    </Style>

</ResourceDictionary>
