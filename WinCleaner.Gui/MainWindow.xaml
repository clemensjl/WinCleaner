<Window x:Class="WinCleaner.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WinCleaner.Gui.ViewModels"
        xmlns:views="clr-namespace:WinCleaner.Gui.Views"
        Title="WinCleaner" Height="720" Width="1080"
        MinHeight="560" MinWidth="880"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Background="{DynamicResource BgBase}">

    <Window.Resources>
        <!-- Seite (ViewModel) -> Ansicht -->
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}"><views:DashboardView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:CleanupViewModel}"><views:CleanupView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:StorageViewModel}"><views:StorageView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProgramsViewModel}"><views:ProgramsView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:StartupServicesViewModel}"><views:StartupServicesView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:PrivacyViewModel}"><views:PrivacyView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SecureDeleteViewModel}"><views:SecureDeleteView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SystemViewModel}"><views:SystemView /></DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="224" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ===== Navigationsleiste ===== -->
        <Border Grid.Column="0" Background="{DynamicResource BgSurface}"
                BorderBrush="{DynamicResource Border}" BorderThickness="0,0,1,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="18,20,18,14">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xEA18;" FontFamily="{StaticResource FontIcon}"
                                   FontSize="18" Foreground="{DynamicResource Accent}"
                                   VerticalAlignment="Center" Margin="0,0,9,0" />
                        <TextBlock Text="WinCleaner" FontFamily="{StaticResource FontDisplay}"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding VersionText}" Style="{StaticResource Eyebrow}" Margin="1,4,0,0" />
                </StackPanel>

                <ListBox ItemsSource="{Binding Pages}" SelectedItem="{Binding Current, Mode=TwoWay}"
                         Background="Transparent" BorderThickness="0" Padding="0,4"
                         ItemContainerStyle="{StaticResource NavItem}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
            </DockPanel>
        </Border>

        <!-- ===== Inhalt + Statusleiste ===== -->
        <DockPanel Grid.Column="1">
            <Border DockPanel.Dock="Bottom" Background="{DynamicResource BgSurface}"
                    BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0" Padding="18,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding Status}" Style="{StaticResource Muted}"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                    <ProgressBar Grid.Column="1" Width="150" Height="4" IsIndeterminate="True"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{DynamicResource Accent}"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" />
                </Grid>
            </Border>

            <ContentControl Content="{Binding Current}" Margin="0" />
        </DockPanel>
    </Grid>
</Window>
